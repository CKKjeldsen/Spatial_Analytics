names(districts_utm_res)
# Trees per residential building
districts_utm_res <- districts_utm_res %>%
mutate(trees_per_res_building = tree_count / pmax(residential_count, 1))
trees_per_res_building_map <- tm_basemap("Esri.WorldGrayCanvas") +
tm_shape(districts_utm_res) +
tm_polygons(
fill        = "trees_per_res_building",
fill.scale  = tm_scale_intervals(
breaks = seq(0, 10, by = 1),
values = rev(hcl.colors(20, "YlGn"))),
fill.legend = tm_legend(title = "Trees / residential building"),
col         = "grey40",
lwd         = 0.8,
fill_alpha  = 0.7) +
tm_text("navn", size = 0.6)
# Save to output folder
tmap_save(tm = trees_per_res_building_map, filename = "C:/Users/ckjel.CK_THINKPAD/Desktop/CDS_Spatial/cds-spatial/Exam/output/trees_per_res_building_map.png", dpi = 300)
trees_per_res_building_map <- tm_basemap("Esri.WorldGrayCanvas") +
tm_shape(districts_utm_res) +
tm_polygons(
fill = "trees_per_res_building",
fill.scale = tm_scale_intervals(breaks = seq(0, 10, by = 1), values = rev(hcl.colors(20, "YlGn"))),
fill.legend = tm_legend(title = "Trees / residential building"),
col = "grey40",
lwd = 0.8,
fill_alpha = 0.7) +
tm_text("navn", size = 0.6)
# Find the ratio between the least-served and most-served districts
districts_utm_res %>%
st_drop_geometry() %>%
select(navn, trees_per_res_building) %>%
arrange(desc(trees_per_res_building)) %>%
slice(c(1, n())) %>%
mutate(
ratio = first(trees_per_res_building) / last(trees_per_res_building)
)
