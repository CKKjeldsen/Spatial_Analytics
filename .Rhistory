make_density_map <- function(sf_obj, density_col, title) {
tm_basemap("Esri.WorldGrayCanvas") +
tm_shape(sf_obj %>% filter(.data[[density_col]] > 0)) +
tm_polygons(
fill        = density_col,
fill.scale  = tm_scale_intervals(
style  = "quantile",
n      = 6,
values = rev(hcl.colors(6, "YlGn"))
),
fill.legend = tm_legend(title = "Trees / km²"),
fill_alpha  = 0.8,
col         = "grey",
lwd         = 0.3
) +
tm_layout(title = title, legend.outside = TRUE)
}
